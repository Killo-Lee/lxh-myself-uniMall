<wxs src="../../wxs/number.wxs" module="wxs"></wxs>
<view class="container"><view class="search-bar"><view data-event-opts="{{[['tap',[['toSearchPage',['$event']]]]]}}" class="search-box" bindtap="__e"><image class="search-img" src="/static/images/icon/search.png"></image><text class="sear-input">搜索您想要的商品</text></view></view><view class="main"><scroll-view class="leftmenu" scroll-y="true"><block wx:for="{{categoryList}}" wx:for-item="item" wx:for-index="index" wx:key="index"><block><view class="{{['menu-item '+(selIndex==index?'active':'')+' ']}}" data-index="{{index}}" data-id="{{item.categoryId}}" data-event-opts="{{[['tap',[['onMenuTab',['$event']]]]]}}" bindtap="__e">{{''+item.categoryName+''}}</view></block></block><block wx:if="{{$root.g0}}"><view class="ca-empty">暂无分类</view></block></scroll-view><scroll-view class="rightcontent" scroll-y="true"><block wx:if="{{categoryImg}}"><view class="adver-map"><view class="item-a"><image src="{{categoryImg}}" mode="widthFix"></image></view></view></block><block wx:if="{{$root.g1}}"><view class="cont-item"><block wx:for="{{productList}}" wx:for-item="item" wx:for-index="index" wx:key="index"><block><view class="show-item" data-prodid="{{item.prodId}}" data-event-opts="{{[['tap',[['toProdPage',['$event']]]]]}}" bindtap="__e"><view class="more-prod-pic"><image class="more-pic" src="{{item.pic}}" mode="widthFix"></image></view><view class="prod-text-right"><view class="prod-text more">{{item.prodName}}</view><view class="cate-prod-info">{{item.brief}}</view><view class="prod-price more"><text class="symbol">￥</text><text class="big-num">{{wxs.parsePrice(item.price)[0]}}</text><text class="small-num">{{"."+wxs.parsePrice(item.price)[1]}}</text></view></view></view></block></block></view></block><block wx:if="{{!$root.g2}}"><view class="cont-item empty">{{$root.g3?'该分类下暂无商品':'暂无商品'}}</view></block></scroll-view></view></view>