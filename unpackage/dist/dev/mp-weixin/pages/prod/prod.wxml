<wxs src="../../wxs/number.wxs" module="wxs"></wxs>
<view class="container"><swiper indicator-dots="{{indicatorDots}}" autoplay="{{autoplay}}" indicator-color="{{indicatorColor}}" interval="{{interval}}" duration="{{duration}}" indicator-active-color="{{indicatorActiveColor}}"><block wx:for="{{imgs}}" wx:for-item="item" wx:for-index="index" wx:key="index"><block><swiper-item><image src="{{item}}"></image></swiper-item></block></block></swiper><view class="prod-info"><view class="tit-wrap"><view class="prod-tit">{{prodName}}</view><view data-event-opts="{{[['tap',[['addOrCannelCollection',['$event']]]]]}}" class="col" bindtap="__e"><block wx:if="{{!isCollection}}"><image src="/static/images/icon/prod-col.png"></image></block><block wx:if="{{isCollection}}"><image src="/static/images/icon/prod-col-red.png"></image></block> 收藏 </view></view><view class="sales-p">{{brief}}</view><view class="prod-price"><block wx:if="{{defaultSku&&defaultSku.price}}"><text class="price">￥<text class="price-num">{{wxs.parsePrice(defaultSku.price)[0]}}</text>{{"."+wxs.parsePrice(defaultSku.price)[1]}}</text></block><block wx:if="{{defaultSku&&defaultSku.oriPrice}}"><text class="ori-price">{{'￥'+wxs.parsePrice(defaultSku.oriPrice)[0]+"."+wxs.parsePrice(defaultSku.oriPrice)[1]+''}}</text></block><text class="sales"></text></view></view><view data-event-opts="{{[['tap',[['showSku',['$event']]]]]}}" class="sku" bindtap="__e"><view class="sku-tit">已选</view><view class="sku-con">{{($root.g0>0?selectedProp+'，':'')+prodNum+"件"}}</view><view class="more">...</view></view><view class="cmt-wrap"><view data-event-opts="{{[['tap',[['showComment',['$event']]]]]}}" class="cmt-tit" bindtap="__e"><view class="cmt-t"> 评价 <text class="cmt-good">{{"好评"+prodCommData.positiveRating+"%"}}</text></view><view class="cmt-count">{{'共'+prodCommData.number+'条'}}<text class="cmt-more"></text></view></view><view class="cmt-cont"><view data-event-opts="{{[['tap',[['showComment',['$event']]]]]}}" class="cmt-tag" bindtap="__e"><text>{{"全部("+prodCommData.number+")"}}</text><text>{{"好评("+prodCommData.praiseNumber+")"}}</text><text>{{"中评("+prodCommData.secondaryNumber+")"}}</text><text>{{"差评("+prodCommData.negativeNumber+")"}}</text><text>{{"有图("+prodCommData.picNumber+")"}}</text></view><view class="cmt-items"><block wx:for="{{$root.l0}}" wx:for-item="item" wx:for-index="index" wx:key="index"><view class="cmt-item"><view class="cmt-user"><text class="date">{{item.$orig.recTime}}</text><view class="cmt-user-info"><image class="user-img" src="{{item.$orig.pic}}"></image><view class="nickname">{{item.$orig.nickName}}</view></view></view><view class="cmt-cnt">{{item.$orig.content}}</view><block wx:if="{{item.g1}}"><scroll-view class="cmt-attr" scroll-x="true"><block wx:for="{{item.$orig.pics}}" wx:for-item="commPic" wx:for-index="index2" wx:key="index2"><image src="{{commPic}}"></image></block></scroll-view></block></view></block></view><block wx:if="{{$root.g2>2}}"><view class="cmt-more-v"><text data-event-opts="{{[['tap',[['showComment',['$event']]]]]}}" bindtap="__e">查看全部评价</text></view></block></view></view><view class="prod-detail"><view><rich-text nodes="{{content}}"></rich-text></view></view><view class="cart-footer"><view data-event-opts="{{[['tap',[['toHomePage',['$event']]]]]}}" class="btn icon" bindtap="__e"><image src="/static/images/tabbar/homepage.png"></image> 首页 </view><view data-event-opts="{{[['tap',[['toCartPage',['$event']]]]]}}" class="btn icon" bindtap="__e"><image src="/static/images/tabbar/basket.png"></image> 购物车 <block wx:if="{{totalCartNum>0}}"><view class="badge badge-1">{{totalCartNum}}</view></block></view><view data-event-opts="{{[['tap',[['showSku',['$event']]]]]}}" class="btn cart" bindtap="__e"><text>加入购物车</text></view><view data-event-opts="{{[['tap',[['showSku',['$event']]]]]}}" class="btn buy" bindtap="__e"><text>立即购买</text></view></view><block wx:if="{{skuShow}}"><view class="pup-sku"><view class="pup-sku-main"><view class="pup-sku-header"><image class="pup-sku-img" src="{{defaultSku.pic?defaultSku.pic:pic}}"></image><view class="pup-sku-price"> ￥ <block wx:if="{{defaultSku&&defaultSku.price}}"><text class="pup-sku-price-int">{{wxs.parsePrice(defaultSku.price)[0]}}</text></block>{{'.'+wxs.parsePrice(defaultSku.price)[1]+''}}</view><view class="pup-sku-prop"><text>已选</text>{{''+($root.g3>0?selectedProp+'，':'')+prodNum+'件'}}</view><view data-event-opts="{{[['tap',[['closePopup',['$event']]]]]}}" class="close" bindtap="__e"></view></view><view class="pup-sku-body"><view class="pup-sku-area"><block wx:for="{{skuGroup}}" wx:for-item="value" wx:for-index="key" wx:key="key"><block><view class="sku-kind">{{key}}</view><view class="sku-choose"><block wx:for="{{value}}" wx:for-item="item" wx:for-index="index" wx:key="index"><block><text class="{{['sku-choose-item '+(wxs.array_contain(selectedProp,item)?'active':'')+' '+(wxs.props_contain(allProperties,selectedPropObj,key,item,propKeys)?'':'gray')]}}" data-ok="{{wxs.props_contain(allProperties,selectedPropObj,key,item,propKeys)}}" data-key="{{key}}" data-val="{{item}}" data-event-opts="{{[['tap',[['toChooseItem',['$event']]]]]}}" bindtap="__e">{{item}}</text></block></block></view></block></block></view><view class="pup-sku-count"><view class="num-wrap"><view data-event-opts="{{[['tap',[['onCountMinus',['$event']]]]]}}" class="minus" bindtap="__e"><text class="row"></text></view><view class="text-wrap"><input type="number" disabled="{{true}}" value="{{prodNum}}"/></view><view data-event-opts="{{[['tap',[['onCountPlus',['$event']]]]]}}" class="plus" bindtap="__e"><text class="row"></text><text class="col"></text></view></view><view class="count-name">数量</view></view></view><view class="pup-sku-footer"><view data-event-opts="{{[['tap',[['addToCart',['$event']]]]]}}" class="btn cart" bindtap="__e">加入购物车</view><view data-event-opts="{{[['tap',[['buyNow',['$event']]]]]}}" class="btn buy" bindtap="__e">立即购买</view></view></view></view></block><block wx:if="{{commentShow}}"><view class="cmt-popup"><view class="cmt-tit"><view class="cmt-t"> 商品评价 <text class="cmt-good">{{"好评度"+prodCommData.positiveRating+"%"}}</text></view><text data-event-opts="{{[['tap',[['closePopup',['$event']]]]]}}" class="close" bindtap="__e"></text></view><view class="cmt-cont"><view class="cmt-tag"><text class="{{[evaluate==-1?'selected':'']}}" data-evaluate="-1" data-event-opts="{{[['tap',[['getProdCommPage',['$event']]]]]}}" bindtap="__e">{{"全部("+prodCommData.number+")"}}</text><text class="{{[evaluate==0?'selected':'']}}" data-evaluate="0" data-event-opts="{{[['tap',[['getProdCommPage',['$event']]]]]}}" bindtap="__e">{{"好评("+prodCommData.praiseNumber+")"}}</text><text class="{{[evaluate==1?'selected':'']}}" data-evaluate="1" data-event-opts="{{[['tap',[['getProdCommPage',['$event']]]]]}}" bindtap="__e">{{"中评("+prodCommData.secondaryNumber+")"}}</text><text class="{{[evaluate==2?'selected':'']}}" data-evaluate="2" data-event-opts="{{[['tap',[['getProdCommPage',['$event']]]]]}}" bindtap="__e">{{"差评("+prodCommData.negativeNumber+")"}}</text><text class="{{[evaluate==3?'selected':'']}}" data-evaluate="3" data-event-opts="{{[['tap',[['getProdCommPage',['$event']]]]]}}" bindtap="__e">{{"有图("+prodCommData.picNumber+")"}}</text></view><view class="cmt-items"><block wx:if="{{$root.g4}}"><block><block wx:for="{{$root.l1}}" wx:for-item="item" wx:for-index="index" wx:key="index"><view class="cmt-item"><view class="cmt-user"><text class="date">{{item.$orig.recTime}}</text><view class="cmt-user-info"><image class="user-img" src="{{item.$orig.pic}}"></image><view class="nickname">{{item.$orig.nickName}}</view></view></view><view class="cmt-cnt">{{item.$orig.content}}</view><block wx:if="{{item.g5}}"><scroll-view class="cmt-attr" scroll-x="true"><block wx:for="{{item.$orig.pics}}" wx:for-item="commPic" wx:for-index="index2" wx:key="index2"><image src="{{commPic}}"></image></block></scroll-view></block><block wx:if="{{item.$orig.replyContent}}"><view class="cmt-reply"><text class="reply-tit">店铺回复：</text>{{''+item.$orig.replyContent+''}}</view></block></view></block></block></block><block wx:if="{{!$root.g6}}"><view class="empty">暂无评价</view></block></view><block wx:if="{{prodCommPage.pages>prodCommPage.current}}"><view class="load-more"><text data-event-opts="{{[['tap',[['getMoreCommPage',['$event']]]]]}}" bindtap="__e">点击加载更多</text></view></block></view></view></block></view>