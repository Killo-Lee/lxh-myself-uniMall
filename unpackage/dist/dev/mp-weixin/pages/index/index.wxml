<wxs src="../../wxs/number.wxs" module="wxs"></wxs>
<view class="container"><view class="bg-sear"><view class="scrolltop"><view data-event-opts="{{[['tap',[['toSearchPage',['$event']]]]]}}" class="section" bindtap="__e"><image class="search-img" src="/static/images/icon/search.png"></image><text class="placeholder">搜索</text></view></view></view><view class="content"><swiper class="pic-swiper" autoplay="{{autoplay}}" indicator-color="{{indicatorColor}}" interval="{{interval}}" duration="{{duration}}" indicator-active-color="{{indicatorActiveColor+' '}}" circular="true" indicator-dots="{{true}}" previous-margin="20rpx" next-margin="20rpx"><block wx:for="{{indexImgs}}" wx:for-item="item" wx:for-index="index" wx:key="index"><block><swiper-item class="banner-item"><view class="img-box"><image class="banner" src="{{item.imgUrl}}" data-prodid="{{item.relation}}" data-event-opts="{{[['tap',[['toProdPage',['$event']]]]]}}" bindtap="__e"></image></view></swiper-item></block></block></swiper><view class="cat-item"><view class="item" data-sts="1" data-event-opts="{{[['tap',[['toClassifyPage',['$event']]]]]}}" bindtap="__e"><image src="/static/images/icon/newProd.png"></image><text>新品推荐</text></view><view class="item" data-sts="1" data-event-opts="{{[['tap',[['toClassifyPage',['$event']]]]]}}" bindtap="__e"><image src="/static/images/icon/timePrice.png"></image><text>限时特惠</text></view><view class="item" data-sts="3" data-event-opts="{{[['tap',[['toClassifyPage',['$event']]]]]}}" bindtap="__e"><image src="/static/images/icon/neweveryday.png"></image><text>每日疯抢</text></view><view data-event-opts="{{[['tap',[['toCouponCenter',['$event']]]]]}}" class="item" bindtap="__e"><image src="/static/images/icon/newprods.png"></image><text>领优惠券</text></view></view><block wx:if="{{$root.g0}}"><view data-event-opts="{{[['tap',[['onNewsPage',['$event']]]]]}}" class="message-play" bindtap="__e"><image class="hornpng" src="/static/images/icon/horn.png"></image><swiper class="swiper-cont" vertical="{{true}}" autoplay="{{true}}" circular="{{true}}" duration="1000"><block wx:for="{{news}}" wx:for-item="item" wx:for-index="index" wx:key="index"><block><swiper-item class="items">{{item.title}}</swiper-item></block></block></swiper><text class="arrow"></text></view></block></view><block wx:if="{{updata}}"><view class="updata"><block wx:for="{{$root.l0}}" wx:for-item="item" wx:for-index="index" wx:key="index"><block><block wx:if="{{item.g1}}"><view class="up-to-date"><view class="title"><text>{{item.$orig.title}}</text><view class="more-prod-cont" data-sts="0" data-id="{{item.$orig.id}}" data-title="{{item.$orig.title}}" data-event-opts="{{[['tap',[['toClassifyPage',['$event']]]]]}}" bindtap="__e"><text class="more">查看更多</text></view></view><view class="item-cont"><block wx:for="{{item.$orig.prods}}" wx:for-item="prod" wx:for-index="index2" wx:key="index2"><block><view class="prod-item" data-prodid="{{prod.prodId}}" data-event-opts="{{[['tap',[['toProdPage',['$event']]]]]}}" bindtap="__e"><view><view class="imagecont"><image class="prodimg" src="{{prod.pic}}"></image></view><view class="prod-text">{{prod.prodName}}</view><view class="price"><text class="symbol">￥</text><text class="big-num">{{wxs.parsePrice(prod.price)[0]}}</text><text class="small-num">{{"."+wxs.parsePrice(prod.price)[1]}}</text></view></view></view></block></block></view></view></block><block wx:if="{{item.g2}}"><view class="hot-sale"><view class="title"><text>{{item.$orig.title}}</text><view class="more-prod-cont" data-sts="0" data-id="{{item.$orig.id}}" data-title="{{item.$orig.title}}" data-event-opts="{{[['tap',[['toClassifyPage',['$event']]]]]}}" bindtap="__e"><text class="more">更多</text><text class="arrow"></text></view></view><view class="hotsale-item-cont"><block wx:for="{{item.$orig.prods}}" wx:for-item="prod" wx:for-index="index2" wx:key="index2"><block><view class="prod-items" data-prodid="{{prod.prodId}}" data-event-opts="{{[['tap',[['toProdPage',['$event']]]]]}}" bindtap="__e"><view class="hot-imagecont"><image class="hotsaleimg" src="{{prod.pic}}"></image></view><view class="hot-text"><view class="hotprod-text">{{prod.prodName}}</view><view class="prod-info">{{prod.brief}}</view><view class="prod-text-info"><view class="price"><text class="symbol">￥</text><text class="big-num">{{wxs.parsePrice(prod.price)[0]}}</text><text class="small-num">{{"."+wxs.parsePrice(prod.price)[1]}}</text></view><image class="basket-img" src="/static/images/tabbar/basket-sel.png"></image></view></view></view></block></block></view></view></block><block wx:if="{{item.g3}}"><view class="more-prod"><view class="title">{{item.$orig.title}}</view><view class="prod-show"><block wx:for="{{item.$orig.prods}}" wx:for-item="prod" wx:for-index="index2" wx:key="index2"><block><view class="show-item" data-prodid="{{prod.prodId}}" data-event-opts="{{[['tap',[['toProdPage',['$event']]]]]}}" bindtap="__e"><view class="more-prod-pic"><image class="more-pic" src="{{prod.pic}}"></image></view><view class="prod-text-right"><view class="prod-text more">{{prod.prodName}}</view><view class="prod-info">{{prod.brief}}</view><view class="b-cart"><view class="price"><text class="symbol">￥</text><text class="big-num">{{wxs.parsePrice(prod.price)[0]}}</text><text class="small-num">{{"."+wxs.parsePrice(prod.price)[1]}}</text></view><image class="basket-img" src="/static/images/tabbar/basket-sel.png" data-event-opts="{{[['tap',[['addToCart',['$0'],[[['taglist','',index],['prods','',index2]]]]]]]}}" catchtap="__e"></image></view></view></view></block></block></view></view></block></block></block></view></block></view>